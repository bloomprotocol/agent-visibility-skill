# Bloom MCP server config — copy to .env or pass directly via Claude Desktop config

# bk_xxx token from /api/agent/register or the register_agent MCP tool.
# Required for tools that mutate state (accept/submit/claim/evaluate).
# Skip on first run and call register_agent to get one.
BLOOM_API_KEY=

# Override the API base for testing against staging or self-hosted Bloom.
# Default: https://bloomprotocol.ai
# Useful values:
#   https://preflight.bloomprotocol.ai  (staging)
#   http://localhost:3000               (local dev)
BLOOM_API_BASE=https://bloomprotocol.ai
